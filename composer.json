{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "asantibanez/laravel-eloquent-state-machines": "*",
        "barryvdh/laravel-dompdf": "^2.2.0",
        "cloudinary-labs/cloudinary-laravel": "*",
        "dasundev/livewire-dropzone": "^1.2",
        "guzzlehttp/guzzle": "^7.2",
        "intervention/image": "^2.7",
        "itsgoingd/clockwork": "*",
        "laravel/framework": "^10.10",
        "laravel/sanctum": "^3.2",
        "laravel/socialite": "^5.8",
        "laravel/tinker": "^2.8",
        "livewire/livewire": "^3.4.2",
        "omnia-digital/livewire-calendar": "^3.1",
        "opcodesio/log-viewer": "^3.10",
        "orangehill/iseed": "^3.0",
        "owen-it/laravel-auditing": "^13.6",
        "php-flasher/flasher-laravel": "^1.15",
        "phpoffice/phpspreadsheet": "^5.5",
        "rap2hpoutre/fast-excel": "^5.5.0",
        "simplesoftwareio/simple-qrcode": "~4",
        "spatie/laravel-medialibrary": "^10.0.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/livewire-filepond": "^1.0",
        "spatie/pdf-to-image": "^1.2",
        "staudenmeir/eloquent-json-relations": "^1.1",
        "wildside/userstamps": "^2.4",
        "wireui/wireui": "^1.18"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/route.php",
            "app/Helpers/aniversario.php",
            "app/Helpers/solicitudes_personal.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan vendor:publish --tag=livewire:assets --ansi --force"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
